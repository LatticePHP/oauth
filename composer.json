{
    "name": "lattice/oauth",
    "description": "OAuth2 authorization server for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "oauth",
        "oauth2",
        "authorization",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/oauth"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\OAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\OAuth\\Tests\\": "tests/"
        }
    }
}
